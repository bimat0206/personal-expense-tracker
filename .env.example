# Backend server port
PORT=3001

# Path to the SQLite database file (relative to backend working dir, or absolute)
DATABASE_PATH=../data/expense-tracker.db

# Path to the attachments folder
ATTACHMENTS_PATH=../data/attachments

# Path for temporary CSV upload files
TMP_IMPORTS_PATH=../data/tmp/imports

# Set to "true" to allow binding on non-loopback interfaces (LAN exposure).
# WARNING: The API has no authentication. Only enable this on a trusted private network.
ALLOW_NON_LOCAL_BIND=false

# Log level: debug | info | warn | error
LOG_LEVEL=info
